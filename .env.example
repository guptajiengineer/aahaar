# ──────────────────────────────────────────
# Aahaar — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────

# ── Server ─────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ────────────────────────────────
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ── JWT ─────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Admin Account ───────────────────────────
# Password for auto-created admin@aahaar.com account (on first boot)
ADMIN_PASSWORD=YourStrongAdminPassword!

# ── Frontend URL (for CORS + email links) ───
# Local dev:      http://localhost:5173
# Production:     https://your-app-name.onrender.com
CLIENT_URL=http://localhost:5173

# ── Cloudinary (photo uploads) ──────────────
# Free account at https://cloudinary.com
# App works without this — uploads are silently skipped
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email / SMTP (password reset, approvals) ─
# Gmail: enable 2FA → generate App Password at
# https://myaccount.google.com/apppasswords
# App works without this — emails are silently skipped
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Twilio (SMS — optional, not yet wired) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
